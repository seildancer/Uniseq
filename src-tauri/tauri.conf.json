{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Uniseq",
  "version": "0.1.0",
  "identifier": "com.uniseq.app",
  "build": {
    "beforeDevCommand": "npm --prefix web run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm --prefix web run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Uniseq",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": false
  }
}
