{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Uniseq",
  "version": "0.1.8",
  "identifier": "com.seildancer.uniseq",
  "build": {
    "beforeDevCommand": "npm --prefix web run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm --prefix ../web run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Uniseq",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "uniseq"
        ]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}